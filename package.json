{
  "name": "gork-slack",
  "version": "1.0.0",
  "license": "MIT",
  "description": "A human-like bot (called Gork) that is almost indistinguishable from a real person. This is a port of the original Gork for Discord to Slack.",
  "private": true,
  "scripts": {
    "dev": "bun run --watch server/index.ts",
    "start": "bun run server/index.ts",
    "check": "ultracite check .",
    "check:spelling": "cspell -c .cspell.jsonc --no-progress --no-summary --no-must-find-files --unique --cache",
    "check:unsafe": "ultracite fix --unsafe true .",
    "check:write": "ultracite fix .",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@date-fns/tz": "^1.4.1",
    "@exalabs/ai-sdk": "^2.0.1",
    "@langfuse/otel": "^5.2.0",
    "@langfuse/tracing": "^5.2.0",
    "@openrouter/ai-sdk-provider": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@pinecone-database/pinecone": "^7.2.0",
    "@slack/bolt": "^4.7.1",
    "@slack/types": "^2.20.1",
    "@t3-oss/env-core": "^0.13.11",
    "ai": "^6.0.168",
    "ai-retry": "^1.5.0",
    "chalk": "^5.6.2",
    "date-fns": "^4.1.0",
    "p-queue": "^9.1.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@cspell/dict-bash": "^4.2.2",
    "@types/bun": "^1.3.13",
    "cspell": "^10.0.0",
    "lefthook": "^2.1.6",
    "typescript": "^6.0.3",
    "ultracite": "7.6.1"
  }
}
